// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model BundleOffer {
  id               String   @id @default(cuid())
  shop             String
  title            String
  offerType        String   @default("quantity_break")
  status           String   @default("draft")
  productIds       String
  tiers            String
  discountIds      String   @default("[]")
  discountUses     Int      @default(0)
  revenueGenerated Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop, status])
}

model ShopSettings {
  shop              String   @id
  billingPlan       String   @default("free")
  pendingBillingPlan String  @default("")
  totalRevenue      Float    @default(0)
  onboardingDone    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Merchant-created discount codes (coupons / gift-card-style fixed amounts).
model Coupon {
  id                    String    @id @default(cuid())
  shop                  String
  title                 String
  code                  String
  status                String    @default("draft")
  discountType          String    @default("percentage")
  discountValue         Float
  appliesOncePerCustomer Boolean  @default(true)
  /// "all" = entire store (optional exclusions); "products" = specific products.
  appliesTo             String    @default("all")
  /// JSON array of product GIDs when appliesTo = "products".
  productIds            String    @default("[]")
  /// JSON array of product GIDs excluded when appliesTo = "all".
  excludedProductIds    String    @default("[]")
  /// Managed Shopify collection of eligible products when storewide exclusions exist.
  eligibleCollectionId  String?
  usageLimit            Int?
  startsAt              DateTime?
  endsAt                DateTime?
  discountId            String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([shop, code])
  @@index([shop, status])
}
