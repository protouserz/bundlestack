{% comment %}
  BundleStack quantity break widget.
  Add to product page via Theme Editor → Apps → BundleStack widget.
{% endcomment %}

<div
  id="bundlestack-widget-{{ block.id }}"
  class="bundlestack-widget bundlestack-widget--pending"
  {% if product %}
    data-product-id="gid://shopify/Product/{{ product.id }}"
    data-price-cents="{{ product.selected_or_first_available_variant.price }}"
    data-currency="{{ cart.currency.iso_code }}"
  {% endif %}
  data-proxy-path="/apps/bundlestack/offers"
>
  <div class="bundlestack-widget__header">
    <p class="bundlestack-widget__title">{{ block.settings.heading }}</p>
  </div>
  <div class="bundlestack-widget__tiers" role="group" aria-label="{{ block.settings.heading }}" aria-live="polite">
    <p class="bundlestack-widget__loading">{{ 'bundlestack.widget.loading' | t }}</p>
  </div>
  <p class="bundlestack-widget__attribution">
    {{ 'bundlestack.widget.powered_by' | t }}
  </p>
</div>

{% schema %}
{
  "name": "BundleStack offers",
  "target": "section",
  "templates": ["product"],
  "javascript": "bundlestack-widget.js",
  "stylesheet": "bundlestack-widget.css",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy more, save more"
    }
  ]
}
{% endschema %}
