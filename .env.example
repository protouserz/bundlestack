# Shopify app credentials (from Partners Dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Comma-separated scopes (must match shopify.app.toml)
SCOPES=read_products,write_products,write_discounts,read_discounts

# Public URL of your deployed app (HTTPS required for App Store)
SHOPIFY_APP_URL=https://your-production-domain.com

# SQLite database path
# Local dev:
DATABASE_URL=file:./prisma/dev.sqlite
# Production (Fly.io volume example):
# DATABASE_URL=file:/data/production.sqlite

# Public support email (shown on /support — must not contain "Shopify")
# SUPPORT_EMAIL=you@yourdomain.com

# Use test billing on dev stores (no real charges). Set true on Render for review stores.
# SHOPIFY_BILLING_TEST=true
